

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people"></i> <%= group.name %></h2>
        <a href="/groups" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Groups
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <p class="card-text"><%= group.description %></p>
        </div>
    </div>

    <% if (!isMember) { %>
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> You must be a member to view and create posts.
            <form action="/groups/join/<%= group.id %>" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-primary">Join Now</button>
            </form>
        </div>
    <% } else { %>
        <!-- Create Post Form -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Create Post</h5>
            </div>
            <div class="card-body">
                <form action="/groups/<%= group.id %>/post" method="POST">
                    <div class="mb-3">
                        <textarea class="form-control" name="content" rows="3" 
                                  placeholder="Share something with the group..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send"></i> Post
                    </button>
                </form>
            </div>
        </div>

        <!-- Posts -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Group Feed</h5>
            </div>
            <div class="card-body">
                <% if (posts.length === 0) { %>
                    <div class="text-center py-4">
                        <i class="bi bi-chat-left-text" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">No posts yet. Be the first to share!</p>
                    </div>
                <% } else { %>
                    <% posts.forEach(post => { %>
                        <div class="mb-4 pb-3 border-bottom">
                            <div class="d-flex align-items-start">
                                <div class="me-3">
                                    <i class="bi bi-person-circle" style="font-size: 2.5rem;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">
                                        <%= post.first_name && post.last_name 
                                            ? post.first_name + ' ' + post.last_name 
                                            : post.email %>
                                    </h6>
                                    <small class="text-muted">
                                        <%= new Date(post.created_at).toLocaleString() %>
                                    </small>
                                    <p class="mt-2 mb-0"><%= post.content %></p>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    <% } %>
</div>
