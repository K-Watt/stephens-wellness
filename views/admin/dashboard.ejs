

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-shield-lock"></i> Admin Dashboard</h2>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center bg-primary text-white">
                <div class="card-body">
                    <i class="bi bi-people" style="font-size: 2rem;"></i>
                    <h3 class="mt-2"><%= stats.users %></h3>
                    <p class="mb-0">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-success text-white">
                <div class="card-body">
                    <i class="bi bi-activity" style="font-size: 2rem;"></i>
                    <h3 class="mt-2"><%= stats.activities %></h3>
                    <p class="mb-0">Total Activities</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-warning text-white">
                <div class="card-body">
                    <i class="bi bi-clock" style="font-size: 2rem;"></i>
                    <h3 class="mt-2"><%= stats.pendingActivities %></h3>
                    <p class="mb-0">Pending Approvals</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center bg-info text-white">
                <div class="card-body">
                    <i class="bi bi-star" style="font-size: 2rem;"></i>
                    <h3 class="mt-2"><%= stats.totalPoints %></h3>
                    <p class="mb-0">Points Awarded</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <a href="/admin/activities" class="btn btn-outline-primary w-100">
                                <i class="bi bi-check-circle"></i> Approve Activities
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/admin/events" class="btn btn-outline-primary w-100">
                                <i class="bi bi-calendar-plus"></i> Manage Events
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/admin/announcements" class="btn btn-outline-primary w-100">
                                <i class="bi bi-megaphone"></i> Announcements
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/admin/groups" class="btn btn-outline-primary w-100">
                                <i class="bi bi-people"></i> Manage Groups
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Monthly Activity Stats -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Monthly Activity</h5>
                </div>
                <div class="card-body">
                    <% if (monthlyStats.length === 0) { %>
                        <p class="text-muted">No activity data yet.</p>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Month</th>
                                        <th>Activities</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% monthlyStats.forEach(stat => { %>
                                        <tr>
                                            <td><%= stat.month %></td>
                                            <td><span class="badge bg-primary"><%= stat.count %></span></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Top Participants -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Top Participants</h5>
                </div>
                <div class="card-body">
                    <% if (topParticipants.length === 0) { %>
                        <p class="text-muted">No participants yet.</p>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Points</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% topParticipants.forEach(participant => { %>
                                        <tr>
                                            <td>
                                                <%= participant.first_name && participant.last_name 
                                                    ? participant.first_name + ' ' + participant.last_name 
                                                    : participant.email %>
                                            </td>
                                            <td><span class="badge bg-warning"><%= participant.total_points %></span></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
