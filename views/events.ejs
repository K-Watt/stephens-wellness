

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-calendar-event"></i> Events</h2>

    <% if (events.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-calendar-x" style="font-size: 4rem; color: #ccc;"></i>
            <p class="text-muted mt-3">No events scheduled at this time.</p>
        </div>
    <% } else { %>
        <div class="row">
            <% events.forEach(event => { 
                const eventDate = new Date(event.start_datetime);
                const isPast = eventDate < new Date();
            %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 <%= isPast ? 'border-secondary' : '' %>">
                        <div class="card-body">
                            <h5 class="card-title"><%= event.title %></h5>
                            
                            <div class="mb-2">
                                <i class="bi bi-calendar text-primary"></i>
                                <small><%= eventDate.toLocaleDateString() %></small>
                            </div>
                            
                            <div class="mb-2">
                                <i class="bi bi-clock text-primary"></i>
                                <small><%= eventDate.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'}) %></small>
                            </div>
                            
                            <div class="mb-3">
                                <i class="bi bi-geo-alt text-primary"></i>
                                <small><%= event.location %></small>
                            </div>

                            <p class="card-text"><%= event.description %></p>

                            <div class="mb-3">
                                <small class="text-muted">
                                    <i class="bi bi-people"></i> <%= event.rsvp_count %> attending
                                    <% if (event.capacity) { %>
                                        / <%= event.capacity %> capacity
                                    <% } %>
                                </small>
                            </div>

                            <% if (!isPast) { %>
                                <% if (event.user_rsvp_status === 'going') { %>
                                    <form action="/events/cancel-rsvp/<%= event.id %>" method="POST">
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                            <i class="bi bi-x-circle"></i> Cancel RSVP
                                        </button>
                                    </form>
                                <% } else { %>
                                    <form action="/events/rsvp/<%= event.id %>" method="POST">
                                        <button type="submit" class="btn btn-primary btn-sm w-100">
                                            <i class="bi bi-check-circle"></i> RSVP
                                        </button>
                                    </form>
                                <% } %>
                            <% } else { %>
                                <button class="btn btn-secondary btn-sm w-100" disabled>
                                    Past Event
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</div>
