<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Top Bar (matches template) -->
    <header class="top-nav">
        <a href="/" class="nav-home-logo">
            <img src="/images/stephens-logo.svg" alt="Stephens College" class="stephens-block-logo">
        </a>
        <div class="nav-left">
            <a href="/auth/login">Dashboard</a>
            <a href="/auth/login">Groups</a>
            <a href="/auth/login">Events</a>
        </div>
        <div class="nav-center">
            <a href="/" class="nav-brand-link">
                <span>Stephens College Wellness</span>
            </a>
        </div>
        <div class="nav-right">
            <a href="/auth/login"><i class="bi bi-person-circle"></i> Profile</a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section text-white py-5">
        <div class="container">
            <div class="row align-items-center min-vh-50">
                <div class="col-lg-7">
                    <img src="/images/stephens-block-maroon.png" alt="Stephens College" 
                         style="height: 60px; margin-bottom: 24px;">
                    <h1 class="display-4 fw-bold mb-4">Stephens College<br>Wellness Program</h1>
                    <p class="lead mb-4" style="font-size: 1.25rem; opacity: 0.9;">
                        Your journey to better health starts here. Track activities, join groups, 
                        attend events, and earn rewards for living well.
                    </p>
                    <a href="/auth/login" class="btn btn-light btn-lg px-5 py-3">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In to Get Started
                    </a>
                </div>
                <div class="col-lg-5 text-center d-none d-lg-block">
                    <img src="/images/stephens-stars.png" alt="Stephens College" 
                         style="max-height: 280px; opacity: 0.15;">
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-5" style="background-color: var(--sc-cream);">
        <div class="container">
            <h2 class="text-center mb-2" style="color: var(--sc-maroon);">Why Join Our Wellness Program?</h2>
            <div class="gold-divider mx-auto" style="max-width: 200px;"></div>
            <div class="row g-4 mt-3">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center">
                        <div class="card-body p-4">
                            <div style="width: 70px; height: 70px; background: var(--sc-maroon); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                                <i class="bi bi-trophy text-white" style="font-size: 1.8rem;"></i>
                            </div>
                            <h5 class="card-title" style="color: var(--sc-maroon);">Earn Rewards</h5>
                            <p class="card-text text-muted">Get points for healthy activities and track your wellness achievements.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center">
                        <div class="card-body p-4">
                            <div style="width: 70px; height: 70px; background: var(--sc-maroon); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                                <i class="bi bi-people text-white" style="font-size: 1.8rem;"></i>
                            </div>
                            <h5 class="card-title" style="color: var(--sc-maroon);">Join Communities</h5>
                            <p class="card-text text-muted">Connect with colleagues who share your wellness interests.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm text-center">
                        <div class="card-body p-4">
                            <div style="width: 70px; height: 70px; background: var(--sc-maroon); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
                                <i class="bi bi-calendar-check text-white" style="font-size: 1.8rem;"></i>
                            </div>
                            <h5 class="card-title" style="color: var(--sc-maroon);">Attend Events</h5>
                            <p class="card-text text-muted">Participate in wellness events, workshops, and activities.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5" style="background-color: var(--sc-white);">
        <div class="container">
            <h2 class="text-center mb-2" style="color: var(--sc-maroon);">Program Features</h2>
            <div class="gold-divider mx-auto" style="max-width: 200px;"></div>
            <div class="row g-4 mt-3">
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <div style="min-width: 50px; height: 50px; background: rgba(138,30,65,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
                            <i class="bi bi-activity" style="font-size: 1.5rem; color: var(--sc-maroon);"></i>
                        </div>
                        <div>
                            <h5 style="color: var(--sc-maroon);">Activity Tracking</h5>
                            <p class="text-muted">Log your wellness activities like walks, gym sessions, yoga, and more.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <div style="min-width: 50px; height: 50px; background: rgba(138,30,65,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
                            <i class="bi bi-speedometer2" style="font-size: 1.5rem; color: var(--sc-maroon);"></i>
                        </div>
                        <div>
                            <h5 style="color: var(--sc-maroon);">Personal Dashboard</h5>
                            <p class="text-muted">Track your progress with detailed metrics and activity history.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <div style="min-width: 50px; height: 50px; background: rgba(138,30,65,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
                            <i class="bi bi-megaphone" style="font-size: 1.5rem; color: var(--sc-maroon);"></i>
                        </div>
                        <div>
                            <h5 style="color: var(--sc-maroon);">Announcements</h5>
                            <p class="text-muted">Stay informed about new programs, events, and wellness tips.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <div style="min-width: 50px; height: 50px; background: rgba(138,30,65,0.1); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 16px;">
                            <i class="bi bi-graph-up" style="font-size: 1.5rem; color: var(--sc-maroon);"></i>
                        </div>
                        <div>
                            <h5 style="color: var(--sc-maroon);">Points & Rewards</h5>
                            <p class="text-muted">Earn points for activities and events, track your achievements.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section py-5 text-white">
        <div class="container text-center">
            <h2 class="mb-4 fw-bold">Ready to Start Your Wellness Journey?</h2>
            <p class="lead mb-4" style="opacity: 0.9;">Join Stephens College employees on the path to better health.</p>
            <a href="/auth/login" class="btn btn-gold btn-lg px-5 py-3">
                <i class="bi bi-box-arrow-in-right"></i> Sign In Now
            </a>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
